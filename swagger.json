{
    "openapi": "3.0.0",
    "info": {
        "title": "API aluguel de carros",
        "description": "Essa API tem como objetivo facilitar as locações de carro",
        "temOfService": "http://localhost:3333/terms",
        "contatc": {
            "email": "yourEmail@outlook.com"
        },
        "version": "1.0.0"
    },
    "security": [
        {
            "bearerAuth": []
        }
    ],
    "paths": {
        "/v1/user": {
            "post": {
                "description": "Criar Usuario",
                "requestBody": {
                    "description": "Dados necessarios para criação de um novo usuario",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestCreateUser"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseCreateUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/session": {
            "post": {
                "description": "Logar usuario",
                "requestBody": {
                    "description": "Dados necessarios para logar o usuario",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestAuthUser"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseAuthUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/me": {
            "get": {
                "description": "Dados do usuario",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseDetailUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/user/remove": {
            "delete": {
                "description": "Deletar usuario",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "user_id",
                        "in": "query",
                        "description": "ID do usuario",
                        "required": "true",
                        "type": "string",
                        "format": "uuid"
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseDeleteUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/user/edit": {
            "put": {
                "description": "Editar dados do usuario",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "description": "Dados necessarios para a edição do proprio usuario",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestEditUser"
