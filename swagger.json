                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseEditUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/car": {
            "post": {
                "description": "Criar Carro",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "description": "Dados necessarios para criação de um novo carro",
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestCreateCar"
