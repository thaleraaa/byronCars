            }
        },
        "/v1/cars/find": {
            "get": {
                "description": "Obter dados de um carro pelo nome",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "name",
                        "in": "query",
                        "description": "Nome do carro",
                        "required": true,
                        "type": "string"
